{
  "consumer": {
    "name": "factstore-frontend"
  },
  "interactions": [
    {
      "description": "a GET request for all flows",
      "providerStates": [
        {
          "name": "flows exist"
        }
      ],
      "request": {
        "method": "GET",
        "path": "/api/v1/flows"
      },
      "response": {
        "body": [
          {
            "createdAt": "2024-01-01T00:00:00Z",
            "description": "A test flow",
            "id": "7f3f2b99-0000-0000-0000-000000000001",
            "name": "test-flow",
            "requiredAttestationTypes": [
              "junit"
            ],
            "updatedAt": "2024-01-01T00:00:00Z"
          }
        ],
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type",
                  "min": 1
                }
              ]
            },
            "$[*].createdAt": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$[*].description": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$[*].id": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$[*].name": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$[*].requiredAttestationTypes": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$[*].updatedAt": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "status": 200
      }
    },
    {
      "description": "a POST request to assert compliance",
      "providerStates": [
        {
          "name": "a flow with id 7f3f2b99-0000-0000-0000-000000000001 exists"
        }
      ],
      "request": {
        "body": {
          "flowId": "7f3f2b99-0000-0000-0000-000000000001",
          "sha256Digest": "sha256:abc123"
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "method": "POST",
        "path": "/api/v1/assert"
      },
      "response": {
        "body": {
          "details": "No artifacts found with digest sha256:abc123",
          "failedAttestationTypes": [],
          "flowId": "7f3f2b99-0000-0000-0000-000000000001",
          "missingAttestationTypes": [],
          "sha256Digest": "sha256:abc123",
          "status": "NON_COMPLIANT"
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.details": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.failedAttestationTypes": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.flowId": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.missingAttestationTypes": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.sha256Digest": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.status": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "status": 200
      }
    },
    {
      "description": "a POST request to create a flow",
      "providerStates": [
        {
          "name": "no state needed"
        }
      ],
      "request": {
        "body": {
          "description": "A new flow",
          "name": "new-flow",
          "requiredAttestationTypes": [
            "junit",
            "snyk"
          ]
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "method": "POST",
        "path": "/api/v1/flows"
      },
      "response": {
        "body": {
          "createdAt": "2024-01-01T00:00:00Z",
          "description": "A new flow",
          "id": "7f3f2b99-0000-0000-0000-000000000002",
          "name": "new-flow",
          "requiredAttestationTypes": [
            "junit",
            "snyk"
          ],
          "updatedAt": "2024-01-01T00:00:00Z"
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.createdAt": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.description": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.id": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.name": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.requiredAttestationTypes": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.updatedAt": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "status": 201
      }
    }
  ],
  "metadata": {
    "pact-js": {
      "version": "16.3.0"
    },
    "pactRust": {
      "ffi": "0.5.3",
      "models": "1.3.9"
    },
    "pactSpecification": {
      "version": "3.0.0"
    }
  },
  "provider": {
    "name": "factstore-backend"
  }
}